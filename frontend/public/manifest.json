{
  "name": "TeXpedition Stash",
  "short_name": "Stash",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#09090B",
  "theme_color": "#A855F7",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/api/share-receive",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/png", "image/jpeg", "image/webp"]
        }
      ]
    }
  }
}